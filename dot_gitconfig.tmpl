[safe]
	directory = *
	directory = *
[credential]
	helper = cache --timeout=360000
[user]
	email = jlorquin@gmail.com
	name = jlorquin
{{- $gh := lookPath "gh" }}
{{- if $gh }}
[credential "https://github.com"]
	helper =
	helper = !{{ $gh }} auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = !{{ $gh }} auth git-credential
{{- end }}
{{- if eq .chezmoi.hostname "movetosevillawebserver" }}
# OCI always-on box: the local SSH key (~/.ssh/id_ed25519) is passphrase-protected,
# so non-interactive git pushes can't decrypt it. Rewrite SSH GitHub remotes to HTTPS
# so they authenticate via the gh credential helper (no passphrase prompt) instead.
[url "https://github.com/"]
	insteadOf = git@github.com:
{{- end }}
[alias]
	cmp = "!f() { git add -A && git commit -m \"$@\" && git push; }; f"
