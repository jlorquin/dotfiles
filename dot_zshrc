[[ -n "$SSH_CONNECTION" ]] && typeset -g POWERLEVEL9K_INSTANT_PROMPT=off
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="lukerandall"
SPACESHIP_PROMPT_ASYNC=true
SPACESHIP_PROMPT_ADD_NEWLINE=true
SPACESHIP_CHAR_SYMBOL="⚡"
SPACESHIP_PROMPT_ORDER=(
  time
  user
  dir
  git
  line_sep
  char
)

# zsh-autosuggestions (async/zpty) and syntax-highlighting hook ZLE; zpty can't
# get a pty under the Tailscale-SSH PTY on WSL, so ZLE blocks before the prompt.
# Drop them for remote sessions only; keep full UX at the laptop.
if [[ -n "$SSH_CONNECTION" ]]; then
  plugins=(git kubectl kubectx helm ansible)
else
  plugins=(git kubectl kubectx helm ansible zsh-autosuggestions zsh-syntax-highlighting)
fi
source $ZSH/oh-my-zsh.sh
eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv zsh)"

# fnm — Node version manager (owns Node like uv owns Python). Auto-switches per
# repo via .node-version/.nvmrc. Placed after brew shellenv so fnm's Node shim
# wins over the brew `node` still installed for playwright-cli. Default = Node 24.
eval "$(fnm env --use-on-cd)"

ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#663399,standout"
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE="20"
ZSH_AUTOSUGGEST_USE_ASYNC=1
fpath=(~/.zsh/completions $fpath)
autoload -Uz compinit
if [[ $(date +'%j') != $(date -d "@$(stat -c '%Y' ~/.zcompdump 2>/dev/null || echo 0)" +'%j' 2>/dev/null) ]]; then
    compinit
else
    compinit -C
fi
alias kx=kubectx
alias kn=kubens
alias k=kubectl
alias tf=terraform
alias explorer='/mnt/c/windows/explorer.exe'
autoload -U +X bashcompinit && bashcompinit
complete -o nospace -C terraform terraform
export PATH="$HOME/.local/bin:$PATH"
eval "$(zoxide init zsh)"
export PNPM_HOME="/home/gabug/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
export PATH="$HOME/bin:$PATH"

# Python: uv owns all libraries + versions; Linuxbrew owns the interpreter binary + CLI tools.
# Default `python3`/`pip` = uv-managed venv at ~/.venvs/default (standalone CPython 3.13).
# Prepending its bin makes bare `python3 foo.py` resolve there — no activation, no pip --user.
export PATH="$HOME/.venvs/default/bin:$PATH"
[ -s "/home/gabug/.bun/_bun" ] && source "/home/gabug/.bun/_bun"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
if [[ -z "$SSH_CONNECTION" ]]; then
    env=~/.ssh/agent.env
    agent_load_env () { test -f "$env" && . "$env" >| /dev/null ; }
    agent_start () {
        (umask 077; ssh-agent >| "$env")
        . "$env" >| /dev/null ; }
    agent_load_env
    agent_run_state=$(ssh-add -l >| /dev/null 2>&1; echo $?)
    if [ ! "$SSH_AUTH_SOCK" ] || [ $agent_run_state = 2 ]; then
        agent_start
        ssh-add
    elif [ "$SSH_AUTH_SOCK" ] && [ $agent_run_state = 1 ]; then
        ssh-add
    fi
    unset env
fi
